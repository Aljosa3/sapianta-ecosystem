    "filesystem_writes": false,
    "implicit_reads": false,
    "provider_calls": false,
    "lifecycle_transitions": false,
    "replay_mutation": false,
    "sidepanel_updates": false,
    "runtime_mutation": false
  },
  "authority_boundary_guarantees": {
