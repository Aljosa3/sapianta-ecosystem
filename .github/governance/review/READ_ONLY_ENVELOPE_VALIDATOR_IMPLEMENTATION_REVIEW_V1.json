    "side_effects": false
  },
  "allowed_inputs": [
    "envelope object",
    "explicit read-only artifact map"
  ],
  "allowed_outputs": [
    "in-memory validation report"
  ],
  "forbidden_behaviors": [
    "implicit filesystem reads",
    "automatic artifact discovery",
    "report writes to disk",
    "envelope mutation",
    "task package mutation",
    "result package mutation",
    "replay record mutation",
    "lifecycle state mutation",
    "provider calls",
    "execution trigger",
    "approval trigger",
    "sidepanel state update",
    "hidden persistence",
    "API endpoint creation",
    "orchestration behavior",
    "semantic autonomy behavior"
  ],
  "validation_checks": [
    "required envelope fields",
    "deterministic envelope hash",
    "referenced task package metadata",
    "referenced result package metadata",
    "replay references",
    "lifecycle references",
    "authority boundary statement",
    "semantic replay limitation statement",
    "next-step synthesis is not approval",
    "provider boundary consistency"
  ],
  "determinism_requirements": {
    "same_inputs_same_report": true,
    "canonical_json_hashing": true,
    "no_current_time_dependency": true,
    "no_environment_dependency": true,
    "no_network_dependency": true,
    "no_filesystem_discovery_dependency": true,
    "no_randomness": true,
    "deterministic_report_ordering": true
  },
  "read_only_guarantees": {
