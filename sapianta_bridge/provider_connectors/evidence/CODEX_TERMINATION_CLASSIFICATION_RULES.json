{
  "classification_inputs": [
    "stdout",
    "stderr",
    "exit_code",
    "timed_out",
    "process_terminated",
    "idle_window_seconds"
  ],
  "completion_requires": [
    "exit_code == 0",
    "process_terminated == true"
  ],
  "marker_result_rule": "OUTPUT_COMPLETED_PROCESS_RUNNING requires deterministic completion marker plus output quiescence while the process is still running.",
  "rules_name": "CODEX_TERMINATION_CLASSIFICATION_RULES",
  "success_must_not_be_inferred_from_arbitrary_text": true,
  "timeout_without_marker_state": "TIMEOUT_NO_COMPLETION",
  "unknown_fails_closed": true,
  "version": "1.0"
}
